<de.dlyt.yanndroid.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/toolbar_view"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	app:title="Developer Menu"
	app:navigationIcon="@drawable/ic_samsung_back">
	<de.dlyt.yanndroid.oneui.widget.NestedScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true"
		android:scrollbars="vertical"
		app:layout_behavior="@string/sesl_appbar_scrolling_view_behavior">
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/group1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Activity"
					android:textSize="25sp"
					android:textColor="@color/textColor"
					android:layout_gravity="center_horizontal" />

				<androidx.appcompat.widget.SeslSpinner
					android:id="@+id/spinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

				<EditText
					android:id="@+id/edittext4"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:autofillHints=""
					android:padding="8dp"
					android:textSize="20sp"
					android:textColor="@color/textColor"
					android:hint="enter key:"
					android:textColorHint="#607D8B" />

				<EditText
					android:id="@+id/edittext5"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:autofillHints=""
					android:padding="8dp"
					android:textSize="20sp"
					android:textColor="@color/textColor"
					android:hint="enter data:"
					android:textColorHint="#607D8B" />

				<Button
					android:id="@+id/button4"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="start"
					android:textSize="12sp"
					android:textColor="@color/textColor" />

				<LinearLayout
					android:id="@+id/linear4"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal" />
			</LinearLayout>
				<TextView
					android:id="@+id/textview116"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Mode"
					android:textSize="25sp"
					android:textColor="@color/textColor"
					android:layout_gravity="center_horizontal" />
			<LinearLayout
				android:id="@+id/group2"
				android:layout_width="match_parent"
				android:layout_height="match_parent">
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview24"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="trigger - a:1"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview147"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="trigger - a:2"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview118"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="DebugMode On"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview119"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="DebugMode Off"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview124"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Remove data (sp:insight1)"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview132"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Remove data (sp:FileUploadActivity)"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview136"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Remove data (sp:HomeActivity)"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<TextView
						android:id="@+id/textview137"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Remove data (sp:SaioagentActivity)"
						android:textSize="20sp"
						android:textColor="@color/textColor" />
					<Button
						android:id="@+id/button2"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Start Device UI Test"
						android:textSize="12sp"
						android:textColor="@color/textColor" />
					<Button
						android:id="@+id/button3"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Start Theme Test"
						android:textSize="12sp"
						android:textColor="@color/textColor" />
					<LinearLayout
						android:id="@+id/linear8"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal">
						<EditText
							android:id="@+id/edittext2"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:textSize="20sp"
							android:textColor="@color/textColor"
							android:hint="enter Image res name:"
							android:textColorHint="#607D8B" />
						<ImageView
							android:id="@+id/imageview1"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:src="@drawable/default_image"
							android:scaleType="fitCenter" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</de.dlyt.yanndroid.oneui.widget.NestedScrollView>
</de.dlyt.yanndroid.oneui.layout.ToolbarLayout>
