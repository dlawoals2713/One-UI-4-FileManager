<de.dlyt.yanndroid.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:title="업데이트 로그"
    app:navigationIcon="@drawable/ic_samsung_back">

        <de.dlyt.yanndroid.oneui.widget.RoundLinearLayout
	    	android:id="@+id/linear"
	    	android:layout_width="match_parent"
	    	android:layout_height="wrap_content"
	    	android:orientation="vertical">

			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/recyclerview1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
                android:background="@color/groupColor" />
        
 	       <View
		 	   android:layout_width="match_parent"
		        android:layout_height="@dimen/sesl_list_subheader_min_height"
		        android:background="?roundedCornerColor" />
		</de.dlyt.yanndroid.oneui.widget.RoundLinearLayout>
</de.dlyt.yanndroid.oneui.layout.ToolbarLayout>