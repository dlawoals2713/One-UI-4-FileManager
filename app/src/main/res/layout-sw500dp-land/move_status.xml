<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/move_linear1"
		android:layout_width="match_parent"
		android:layout_height="100dp"
		android:gravity="center_vertical"
        android:background="@color/groupColor"
		android:orientation="horizontal">
		<LinearLayout
			android:id="@+id/linear1"
			android:layout_width="100dp"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical">
			<ImageView
				android:id="@+id/move_imageview1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:src="@drawable/default_image"
				android:scaleType="center"
				android:focusable="false" />
			<TextView
				android:id="@+id/move_size"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="4dp"
				android:text="0kb"
				android:textSize="16sp"
				android:textColor="@color/textColor"
				android:focusable="false" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:gravity="left|center_vertical"
			android:orientation="vertical">
			<TextView
				android:id="@+id/move_count"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="249개"
				android:textSize="20sp"
				android:textColor="@color/textColor"
				android:focusable="false" />
			<TextView
				android:id="@+id/move_path"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="원래 위치: /storage/emulated/0"
				android:textSize="16sp"
				android:textColor="@color/textColor"
				android:focusable="false" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="horizontal"
			android:layout_weight="1" />
		<Button
			android:id="@+id/move_cancel"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:text="취소"
			android:textSize="12sp"
			android:textColor="@color/textColor" />
		<Button
			android:id="@+id/move_move"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginRight="36dp"
			android:padding="8dp"
			android:text="여기로 이동"
			android:textSize="12sp"
			android:textColor="@color/textColor" />
	</LinearLayout>
</LinearLayout>
