<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mini_player"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:background="@color/groupColor"
    android:elevation="4dp"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/mini_album_art"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_samsung_file_type_audio"
        android:layout_marginLeft="8dp" />

    <TextView
        android:id="@+id/mini_song_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:text="재생 중인 음악"
        android:textSize="14sp"
        android:textColor="@color/textColor"
        android:maxLines="1"
        android:ellipsize="end" />

    <ImageButton
        android:id="@+id/mini_play_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_samsung_play"
        android:layout_marginRight="24dp"
        android:contentDescription="재생/일시정지 버튼" />
</LinearLayout>