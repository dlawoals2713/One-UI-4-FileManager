<de.dlyt.yanndroid.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/toolbar_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:title="MMF Player"
    app:subtitle="v1.7">

    <de.dlyt.yanndroid.oneui.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_behavior="@string/sesl_appbar_scrolling_view_behavior">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:id="@+id/content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 상단 여백 -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- 메인 컨텐츠 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center">

                    <!-- 파일 이름 -->
                    <TextView
                        android:id="@+id/text_file_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.AppCompat.Small"
                        android:textColor="?android:attr/textColorSecondary"
                        android:text="@string/mmf_file_unselected"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/text_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                                android:text="@string/mmf_init_title"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="4dp"
                                android:background="?android:attr/listDivider"/>

                            <TextView
                                android:id="@+id/text_artist"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:text="@string/mmf_init_artist"/>

                            <TextView
                                android:id="@+id/text_copyright"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:text="@string/mmf_init_copyright"/>

                            <TextView
                                android:id="@+id/text_genre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:text="@string/mmf_init_genre"/>

                            <TextView
                                android:id="@+id/text_misc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:text="@string/mmf_init_etc"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 컨트롤 버튼 그룹 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/button_init"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_samsung_refresh"
                            android:contentDescription="초기화"
                            app:tint="?android:attr/textColorSecondary"
                            tools:ignore="ContentDescription"/>

                        <ImageButton
                            android:id="@+id/button_play"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_samsung_play"
                            android:contentDescription="재생"
                            app:tint="@color/mmf_primaryColor"
                            tools:ignore="ContentDescription"/>

                        <ImageButton
                            android:id="@+id/button_stop"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_samsung_stop"
                            android:contentDescription="정지"
                            app:tint="?android:attr/textColorSecondary"
                            tools:ignore="ContentDescription"/>

                        <ImageButton
                            android:id="@+id/button_release"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_samsung_power"
                            android:contentDescription="서비스 종료"
                            app:tint="@color/mmf_errorColor"
                            tools:ignore="ContentDescription"/>
                    </LinearLayout>

                    <!-- 볼륨 컨트롤 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_samsung_minus"
                            app:tint="?android:attr/textColorSecondary" />

                        <androidx.appcompat.widget.AppCompatSeekBar
                            android:id="@+id/seekbar_volume"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="8dp"
                            android:max="127"
                            android:progress="100"/>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_samsung_plus"
                            app:tint="?android:attr/textColorSecondary" />
                    </LinearLayout>

                    <!-- 재생 진행바 -->
                    <androidx.appcompat.widget.AppCompatSeekBar
                        android:id="@+id/seekbar_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:progressBackgroundTint="?android:attr/textColorHint"
                        android:progressTint="@color/mmf_primaryColor"/>

                    <!-- 재생 시간 -->
                    <TextView
                        android:id="@+id/text_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                        android:text="00:00 / 00:00"/>
                </LinearLayout>

                <!-- 하단 여백 -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </de.dlyt.yanndroid.oneui.widget.NestedScrollView>
</de.dlyt.yanndroid.oneui.layout.ToolbarLayout>